                 "properties":[
                        {
                         "name":"Nha_Tranh",
                         "type":"string",
                         "value":"Sinh ra t\u1ea1i l\u00e0ng Ch\u00f9a (qu\u00ea ngo\u1ea1i) v\u00e0 l\u1edbn l\u00ean \u1edf l\u00e0ng Sen (qu\u00ea n\u1ed9i), Nam \u0110\u00e0n, t\u1ec9nh Ngh\u1ec7 An, c\u1eadu b\u00e9 Nguy\u1ec5n Sinh Cung \u0111\u00e3 tr\u1ea3i qua nh\u1eefng n\u0103m th\u00e1ng tu\u1ed5i th\u01a1 trong m\u1ed9t ng\u00f4i nh\u00e0 tranh \u0111\u01a1n s\u01a1, gi\u1ea3n d\u1ecb. Ch\u00ednh n\u1ebfp nh\u00e0 thanh b\u1ea1ch c\u1ee7a m\u1ed9t gia \u0111\u00ecnh nh\u00e0 nho ngh\u00e8o y\u00eau n\u01b0\u1edbc, c\u00f9ng truy\u1ec1n th\u1ed1ng ki\u00ean c\u01b0\u1eddng c\u1ee7a m\u1ea3nh \u0111\u1ea5t x\u1ee9 Ngh\u1ec7 \u0111\u00e3 \u0111\u1eb7t n\u1ec1n m\u00f3ng \u0111\u1ea7u ti\u00ean cho l\u00f2ng y\u00eau n\u01b0\u1edbc th\u01b0\u01a1ng d\u00e2n s\u00e2u s\u1eafc. Nh\u1eefng h\u00ecnh \u1ea3nh m\u1ed9c m\u1ea1c nh\u01b0 m\u00e1i tranh, gi\u1ebfng n\u01b0\u1edbc, l\u0169y tre l\u00e0ng \u0111\u00e3 nu\u00f4i d\u01b0\u1ee1ng t\u00e2m h\u1ed3n v\u00e0 \u00fd ch\u00ed c\u1ee7a Ng\u01b0\u1eddi tr\u01b0\u1edbc khi b\u01b0\u1edbc ch\u00e2n ra \u0111i t\u00ecm \u0111\u01b0\u1eddng c\u1ee9u n\u01b0\u1edbc."
                        }],
