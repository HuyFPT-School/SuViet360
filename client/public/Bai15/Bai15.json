                 "opacity":1,
                 "properties":[
                        {
                         "name":"Ben_Cang",
                         "type":"string",
                         "value":"Th\u1ea5u hi\u1ec3u n\u1ed7i kh\u1ed5 c\u1ef1c c\u1ee7a nh\u00e2n d\u00e2n d\u01b0\u1edbi \u00e1ch th\u1ed1ng tr\u1ecb c\u1ee7a th\u1ef1c d\u00e2n v\u00e0 ch\u1ee9ng ki\u1ebfn s\u1ef1 th\u1ea5t b\u1ea1i c\u1ee7a c\u00e1c phong tr\u00e0o y\u00eau n\u01b0\u1edbc \u0111\u01b0\u01a1ng th\u1eddi, ng\u00e0y 5\/6\/1911, ng\u01b0\u1eddi thanh ni\u00ean Nguy\u1ec5n T\u1ea5t Th\u00e0nh \u0111\u00e3 quy\u1ebft \u0111\u1ecbnh r\u1eddi B\u1ebfn c\u1ea3ng Nh\u00e0 R\u1ed3ng tr\u00ean con t\u00e0u \u0110\u00f4 \u0111\u1ed1c Latouche-Tr\u00e9ville. V\u1edbi hai b\u00e0n tay tr\u1eafng v\u00e0 m\u1ed9t \u00fd ch\u00ed s\u1eaft \u0111\u00e1, Ng\u01b0\u1eddi b\u1eaft \u0111\u1ea7u cu\u1ed9c h\u00e0nh tr\u00ecnh b\u00f4n ba qua kh\u1eafp c\u00e1c ch\u00e2u l\u1ee5c, t\u1eeb ch\u00e2u \u00c1, ch\u00e2u \u00c2u, ch\u00e2u Phi \u0111\u1ebfn ch\u00e2u M\u1ef9. Ng\u01b0\u1eddi kh\u00f4ng ng\u1ea1i l\u00e0m \u0111\u1ee7 m\u1ecdi c\u00f4ng vi\u1ec7c gian kh\u1ed5 \u0111\u1ec3 v\u1eeba lao \u0111\u1ed9ng ki\u1ebfm s\u1ed1ng, v\u1eeba h\u1ecdc t\u1eadp, nghi\u00ean c\u1ee9u v\u00e0 t\u00ecm ki\u1ebfm con \u0111\u01b0\u1eddng gi\u1ea3i ph\u00f3ng th\u1ef1c s\u1ef1 cho d\u00e2n t\u1ed9c Vi\u1ec7t Nam."
                        }],
